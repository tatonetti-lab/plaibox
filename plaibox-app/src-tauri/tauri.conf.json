{
  "productName": "Plaibox",
  "version": "0.1.0",
  "identifier": "com.plaibox.app",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "bundle": {
    "active": true,
    "targets": "all"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "dangerousDisableAssetCspModification": true
    },
    "windows": [
      {
        "title": "Plaibox",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "resizable": true
      }
    ]
  }
}
